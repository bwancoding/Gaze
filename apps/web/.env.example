# ============================================
# WRHITW Web - Environment Variables
# ============================================

# API Backend URL (set to your Railway URL in production)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: NEXT_PUBLIC_API_URL=https://your-app.up.railway.app

# Site URL for sitemap & OG tags
# NEXT_PUBLIC_SITE_URL=https://wrhitw.com

# Admin Gate Password (REQUIRED)
NEXT_PUBLIC_ADMIN_GATE_PASSWORD=
