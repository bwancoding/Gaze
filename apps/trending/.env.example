# WRHITW Trending API - 环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# 应用配置
APP_NAME=WRHITW Trending API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# API 配置
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4

# 数据库配置
DATABASE_URL=postgresql://wrhitw:password@localhost:5432/wrhitw

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# 缓存配置
CACHE_TTL_SECONDS=300

# 限流配置
RATE_LIMIT_PER_MINUTE=60

# 日志配置
LOG_LEVEL=INFO

# 热度算法配置
HEAT_TIME_DECAY_LAMBDA=0.1
HEAT_COMMENT_WEIGHT=5.0
HEAT_SHARE_WEIGHT=3.0

# 聚类配置
CLUSTER_SIMILARITY_THRESHOLD=0.6
CLUSTER_TOP_KEYWORDS=20

# 抓取配置
RSS_FETCH_TIMEOUT=30
RSS_MAX_ARTICLES_PER_FEED=50
