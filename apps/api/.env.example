# Database
# SQLite (development):
DATABASE_URL=sqlite:///./wrhitw.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@host:5432/wrhitw

# JWT Authentication (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=

# Admin Credentials (REQUIRED - use strong passwords in production)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# AI (DashScope / Qwen)
DASHSCOPE_API_KEY=
# Standard: https://dashscope.aliyuncs.com/compatible-mode/v1
# Coding Plan: https://coding.dashscope.aliyuncs.com/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# App
APP_ENV=development
DEBUG=True
