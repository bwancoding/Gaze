# ============================================
# Gaze API - Environment Variables
# ============================================

# Database (Railway auto-sets DATABASE_URL for PostgreSQL)
DATABASE_URL=sqlite:///./wrhitw.db
# Production: DATABASE_URL=postgresql://user:pass@host:5432/wrhitw

# JWT Authentication (REQUIRED)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=

# Admin Credentials (REQUIRED)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# CORS (set to your Vercel domain in production)
CORS_ORIGINS=http://localhost:3000
# Production: CORS_ORIGINS=https://your-app.vercel.app,https://gaze.app

# AI Service (DashScope / Qwen)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# App
APP_ENV=development
DEBUG=True
# Production: APP_ENV=production, DEBUG=False
